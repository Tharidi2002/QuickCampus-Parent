{
  "apps": [
    {
      "name": "eureka-server",
      "script": "java",
      "args": "-jar eureka-server/target/eureka-server-1.0.0.jar",
      "cwd": "./",
      "instances": 2,
      "exec_mode": "cluster",
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production"
      },
      "log_file": "./logs/eureka-server.log",
      "out_file": "./logs/eureka-server-out.log",
      "error_file": "./logs/eureka-server-error.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    },
    {
      "name": "config-server",
